# ~/.profile: executed by the command interpreter for login shells.
# This file is not read by bash(1), if ~/.bash_profile or ~/.bash_login
# exists.
# see /usr/share/doc/bash/examples/startup-files for examples.
# the files are located in the bash-doc package.

# the default umask is set in /etc/profile; for setting the umask
# for ssh logins, install and configure the libpam-umask package.
#umask 022

# if running bash
if [ -n "$BASH_VERSION" ]; then
    # include .bashrc if it exists
    if [ -f "$HOME/.bashrc" ]; then
	. "$HOME/.bashrc"
    fi
fi

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/bin" ] ; then
    PATH="$HOME/bin:$PATH"
fi

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/.local/bin" ] ; then
    PATH="$HOME/.local/bin:$PATH"
fi

# Detect agent-managed shells (Claude Code, GitHub Copilot, etc.)
# CLAUDECODE is set by `claude` by default
# GITHUB_COPILOT_VSCODE is a custom variable set in ~/.config/Code/User/settings.json
#     "chat.tools.terminal.terminalProfile.linux": {
#         "path": "zsh",
#         "env": {
#             "GITHUB_COPILOT_VSCODE": "1",
#         }
#     }
# with an equivalent for osx
# This will require extension for other agent harnesses
if [ -n "$CLAUDECODE" ] || [ -n "$GITHUB_COPILOT_VSCODE" ]; then
    export AGENT_MANAGED_SHELL=1
fi

# In agent-managed shells, disable paging everywhere
if [ -n "$AGENT_MANAGED_SHELL" ]; then
    export PAGER=cat
    export GIT_PAGER=cat
    export MANPAGER=cat
    export BAT_PAGER=
fi

export PYENV_ROOT="$HOME/.pyenv"
export SSH_KEY_PATH="$HOME/.ssh/rsa_id"
export EDITOR="vim"
export EZA_CONFIG_DIR="$HOME/.config/eza"
export GOPATH="$HOME/.go"
source $HOME/.profile-local
