# Config generated by Ghostty Config

shell-integration-features = sudo,ssh-env,ssh-terminfo
bell-features = system
theme = moss

# CMD + arrows: move focus between splits
keybind = cmd+left=goto_split:left
keybind = cmd+right=goto_split:right
keybind = cmd+up=goto_split:up
keybind = cmd+down=goto_split:down

# CMD + SHIFT + arrows: create a split in that direction
keybind = cmd+shift+left=new_split:left
keybind = cmd+shift+right=new_split:right
keybind = cmd+shift+up=new_split:up
keybind = cmd+shift+down=new_split:down
