{{- $osid := .chezmoi.os -}}
{{- if hasKey .chezmoi.osRelease "id" -}}
{{-   $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

data:
    osid: {{ $osid | quote }}
    cmds:
{{- if eq $osid "linux-ubuntu" }}
        bat: batcat
{{- else if eq $osid "darwin" }}
        bat: bat
{{- end -}}
