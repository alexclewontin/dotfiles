if [[ -n "$ZSH_DEBUGRC" ]]; then
  zmodload zsh/zprof
fi

source ~/.universalrc

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# See https://github.com/robbyrussell/oh-my-zsh/wiki/Themes
ZSH_THEME="acl"

# we are managing updates via chezmoi instead
DISABLE_AUTO_UPDATE="true"

# If we have the eza command and a theme.yml file, disable ls colors to defer
# to the eza theme
if [[ -x $(command -v eza) && -f "$EZA_CONFIG_DIR/theme.yml" ]]; then
	DISABLE_LS_COLORS="true"
fi

# Which plugins would you like to load?
plugins=(git command-not-found zsh-completions)

(( $+commands[rbenv] )) && eval "$(rbenv init -)"
(( $+commands[pyenv] )) && eval "$(pyenv init --path)" && plugins+=(pyenv)


source $ZSH/oh-my-zsh.sh
if (( $+commands[kubectl] )); then
  kubectl_completion_cache="${ZSH_CACHE_DIR:-$HOME/.cache}/kubectl-completion.zsh"
  if [[ ! -s "$kubectl_completion_cache" || "$(command -v kubectl)" -nt "$kubectl_completion_cache" ]]; then
    mkdir -p "${kubectl_completion_cache:h}"
    kubectl completion zsh >| "$kubectl_completion_cache"
  fi
  [[ -s "$kubectl_completion_cache" ]] && source "$kubectl_completion_cache"
fi

# Re-source aliases after oh-my-zsh to prevent it from overwriting them
source ~/.aliases

if [[ -n "$ZSH_DEBUGRC" ]]; then
  zprof
fi
